# Server
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# DNS Resolution
# Comma-separated list of DNS servers to use for resolution
DNS_SERVERS=8.8.8.8,1.1.1.1

# MikroTik API (Optional - only needed for auto-push feature)
MT_HOST=192.168.88.1
MT_USER=admin
MT_PASS=
MT_PORT=8728

# Scheduler
# Interval in hours to auto re-resolve domains and update address lists
SCHEDULER_INTERVAL_HOURS=6
